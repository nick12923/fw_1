# Environment
NODE_ENV=development
PORT=5000

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=fundwisor
DB_USER=postgres
DB_PASSWORD=password
DB_SSL=false

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRY=24h
JWT_REFRESH_EXPIRY=7d

# AWS S3 Configuration (Mock)
S3_BUCKET=fundwisor-documents
S3_REGION=us-east-1
S3_ACCESS_KEY=mock_access_key
S3_SECRET_KEY=mock_secret_key
S3_ENDPOINT=http://localhost:9000

# Razorpay Payment Gateway (Mock)
RAZORPAY_KEY=rzp_test_mock_key
RAZORPAY_SECRET=mock_secret

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=noreply@fundwisor.com

# KYC Provider (Mock)
KYC_PROVIDER=mock
KYC_API_KEY=mock_kyc_api_key

# Logging
LOG_LEVEL=debug
LOG_FILE=logs/app.log

# Security
BCRYPT_ROUNDS=10
CORS_ORIGIN=http://localhost:3000

# Features
ENABLE_MOCK_PAYMENTS=true
ENABLE_MOCK_KYC=true
